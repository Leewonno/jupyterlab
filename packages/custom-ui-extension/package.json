{
  "name": "@jupyterlab/custom-ui-extension",
  "version": "4.6.0-rc.0",
  "description": "JupyterLab - Custom UI Extension (centralized styles)",
  "homepage": "https://github.com/jupyterlab/jupyterlab",
  "bugs": {
    "url": "https://github.com/jupyterlab/jupyterlab/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jupyterlab/jupyterlab.git"
  },
  "license": "BSD-3-Clause",
  "author": "Project Jupyter",
  "sideEffects": [
    "style/**/*"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "directories": {
    "lib": "lib/"
  },
  "files": [
    "lib/*.{d.ts,js,js.map}",
    "style/*.*",
    "style/**/*.*",
    "src/**/*.ts"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf lib tsconfig.tsbuildinfo",
    "watch": "tsc -b --watch"
  },
  "dependencies": {
    "@jupyterlab/application": "^4.6.0-rc.0",
    "@jupyterlab/apputils": "^4.7.0-rc.0",
    "@jupyterlab/custom-api-extension": "^4.6.0-rc.0",
    "@jupyterlab/docregistry": "^4.6.0-rc.0",
    "@jupyterlab/fileeditor": "^4.6.0-rc.0",
    "@jupyterlab/notebook": "^4.6.0-rc.0",
    "@jupyterlab/services": "^7.6.0-rc.0",
    "@jupyterlab/translation": "^4.6.0-rc.0",
    "@jupyterlab/ui-components": "^4.6.0-rc.0",
    "@lumino/widgets": "^2.8.0"
  },
  "devDependencies": {
    "rimraf": "~5.0.5",
    "typescript": "~5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "jupyterlab": {
    "extension": true
  },
  "styleModule": "style/index.js"
}
