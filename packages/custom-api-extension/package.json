{
  "name": "@jupyterlab/custom-api-extension",
  "version": "4.6.0-rc.0",
  "description": "JupyterLab - Custom API Extension (central client for external API connections)",
  "homepage": "https://github.com/jupyterlab/jupyterlab",
  "bugs": {
    "url": "https://github.com/jupyterlab/jupyterlab/issues"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jupyterlab/jupyterlab.git"
  },
  "license": "BSD-3-Clause",
  "author": "Project Jupyter",
  "sideEffects": [
    "style/**/*"
  ],
  "main": "lib/index.js",
  "types": "lib/index.d.ts",
  "style": "style/index.css",
  "directories": {
    "lib": "lib/"
  },
  "files": [
    "lib/*.{d.ts,js,js.map}",
    "src/**/*.ts",
    "style/index.css",
    "style/index.js"
  ],
  "scripts": {
    "build": "tsc -b",
    "clean": "rimraf lib tsconfig.tsbuildinfo",
    "watch": "tsc -b --watch"
  },
  "dependencies": {
    "@jupyterlab/application": "^4.6.0-rc.0",
    "@jupyterlab/docmanager": "^4.6.0-rc.0",
    "@lumino/coreutils": "^2.2.2"
  },
  "devDependencies": {
    "rimraf": "~5.0.5",
    "typescript": "~5.9.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "jupyterlab": {
    "extension": true
  },
  "styleModule": "style/index.js"
}
